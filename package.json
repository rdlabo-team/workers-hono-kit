{
  "name": "@rdlabo/workers-hono-kit",
  "version": "0.5.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Infrastructure toolkit for building APIs on Hono + Cloudflare Workers: Firebase ID-token verification (jose), AWS Secrets Manager (aws4fetch), ETag/validation/zod-coerce middleware, deadlock retry, and shared HTTP helpers.",
  "author": "Masahiko Sakakibara<sakakibara@rdlabo.jp>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rdlabo-team/workers-hono-kit.git"
  },
  "bugs": {
    "url": "https://github.com/rdlabo-team/workers-hono-kit/issues"
  },
  "homepage": "https://github.com/rdlabo-team/workers-hono-kit#readme",
  "keywords": [
    "hono",
    "cloudflare-workers",
    "workers",
    "edge",
    "firebase",
    "jose",
    "aws-secrets-manager",
    "middleware",
    "etag",
    "zod",
    "nestjs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "!src/**/*.spec.ts"
  ],
  "bin": {
    "workers-hono-kit-sync-dev-aws": "./scripts/sync-dev-aws.mjs",
    "workers-hono-kit-check-subrequest-fanout": "./scripts/check-subrequest-fanout.mjs",
    "workers-hono-kit-db-baseline": "./scripts/db-baseline.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./business-time": {
      "types": "./dist/business-time/index.d.ts",
      "import": "./dist/business-time/index.js",
      "default": "./dist/business-time/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "release": "np --no-tests --no-publish"
  },
  "dependencies": {
    "stripe": "^20.4.1"
  },
  "peerDependencies": {
    "@hono/zod-validator": "^0.8.0",
    "ai": "^6.0.0",
    "ai-gateway-provider": "^3.1.0",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "jose": "^6.2.0",
    "mysql2": "^3.14.0",
    "zod": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "ai-gateway-provider": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@hono/eslint-config": "^2.1.0",
    "@hono/zod-validator": "^0.8.0",
    "@types/node": "^22.19.21",
    "ai": "^6.0.204",
    "ai-gateway-provider": "^3.1.3",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "mysql2": "3.22.5",
    "np": "^8.0.4",
    "prettier": "^3.8.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.0",
    "zod": "^4.4.3"
  }
}
