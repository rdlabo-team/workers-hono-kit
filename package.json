{
  "name": "@rdlabo/hono-kit",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Infrastructure toolkit for building APIs on Hono + Cloudflare Workers: Firebase ID-token verification (jose), AWS Secrets Manager (aws4fetch), ETag/validation/zod-coerce middleware, deadlock retry, and shared HTTP helpers.",
  "author": "Masahiko Sakakibara<sakakibara@rdlabo.jp>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rdlabo-team/hono-kit.git"
  },
  "bugs": {
    "url": "https://github.com/rdlabo-team/hono-kit/issues"
  },
  "homepage": "https://github.com/rdlabo-team/hono-kit#readme",
  "keywords": [
    "hono",
    "cloudflare-workers",
    "workers",
    "edge",
    "firebase",
    "jose",
    "aws-secrets-manager",
    "middleware",
    "etag",
    "zod",
    "nestjs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "src",
    "scripts",
    "!src/**/*.spec.ts"
  ],
  "bin": {
    "hono-kit-sync-dev-aws": "./scripts/sync-dev-aws.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "import": "./src/db/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "peerDependencies": {
    "@hono/zod-validator": "^0.8.0",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "jose": "^6.2.0",
    "mysql2": "^3.14.0",
    "stripe": ">=15",
    "zod": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "stripe": { "optional": true },
    "drizzle-orm": { "optional": true },
    "mysql2": { "optional": true }
  },
  "devDependencies": {
    "@hono/eslint-config": "^2.1.0",
    "@hono/zod-validator": "^0.8.0",
    "@types/node": "^22.19.21",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "0.45.2",
    "eslint": "^9.39.4",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "mysql2": "3.22.5",
    "prettier": "^3.8.4",
    "stripe": "^20.4.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.0",
    "zod": "^4.4.3"
  }
}
